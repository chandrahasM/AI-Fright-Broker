SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4.1

# CORS — set to your Vercel frontend URL in production (Railway env var)
# Example: CORS_ORIGINS=https://your-app.vercel.app
# Leave unset or "*" for local development
CORS_ORIGINS=*

# Logging — set to "false" in production (Railway sets RAILWAY_ENVIRONMENT automatically)
LOG_TO_FILE=true
